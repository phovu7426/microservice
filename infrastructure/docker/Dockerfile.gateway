FROM nginx:1.27-alpine

COPY infrastructure/nginx/snippets/ /etc/nginx/snippets/
COPY infrastructure/nginx/nginx.railway.conf /etc/nginx/conf.d/default.conf

# Create static health file so Railway healthcheck always gets 200
# regardless of nginx location-matching behavior.
RUN mkdir -p /etc/nginx/html/health && printf "ok\n" > /etc/nginx/html/health/ready

EXPOSE 80
