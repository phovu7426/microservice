generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  title     String    @db.VarChar(255)
  message   String    @db.Text
  type      String    @default("info") @db.VarChar(30)
  data      Json?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamp(0)
  status    String    @default("active") @db.VarChar(30)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([userId], map: "notifications_idx_user_id")
  @@index([status], map: "notifications_idx_status")
  @@index([type], map: "notifications_idx_type")
  @@index([isRead], map: "notifications_idx_is_read")
  @@index([userId, isRead], map: "notifications_idx_user_read")
  // Composite for the user notification list: filter by user_id, sort by
  // created_at DESC. Without it, Postgres scans `[user_id, is_read]` and
  // re-sorts the working set.
  @@index([userId, createdAt(sort: Desc)], map: "notifications_idx_user_created")
  @@index([userId, isRead, createdAt(sort: Desc)], map: "notifications_idx_user_read_created")
  @@map("notifications")
}

model ContentTemplate {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(255)
  category  String   @default("render") @db.VarChar(30)
  type      String   @db.VarChar(30)
  content   String?  @db.Text
  filePath  String?  @map("file_path") @db.VarChar(500)
  metadata  Json?
  variables Json?
  status    String   @default("active") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([code], map: "idx_content_templates_code")
  @@index([status], map: "idx_content_templates_status")
  @@index([category], map: "idx_content_templates_category")
  @@index([type], map: "idx_content_templates_type")
  @@map("content_templates")
}

model ComicFollowersProjection {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  comicId    BigInt   @map("comic_id")
  followedAt DateTime @default(now()) @map("followed_at") @db.Timestamp(0)

  @@unique([userId, comicId], map: "cfp_idx_user_comic")
  @@index([comicId], map: "cfp_idx_comic_id")
  @@index([userId], map: "cfp_idx_user_id")
  @@map("comic_followers_projection")
}
