# =============================================================================
# Notification Service — Environment Variables
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Notification Service
PORT=3005
NODE_ENV=development
GLOBAL_PREFIX=api/notifications
APP_URL=http://localhost:3005
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5435/notification_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6382

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json
INTERNAL_API_SECRET=change-me-in-production

# ── Upstream services ────────────────────────────────────────────────────────
CONFIG_INTERNAL_URL=http://localhost:3003/api/config

# ── Kafka ─────────────────────────────────────────────────────────────────────
EVENT_DRIVER=kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notification-service
# SSL for Aiven Kafka — leave empty for local plaintext
KAFKA_REPLICATION_FACTOR=3
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
