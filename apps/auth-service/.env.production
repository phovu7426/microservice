# =============================================================================
# Auth Service — Production overrides
# Priority: .env.local > .env.production > .env
# Non-secret vars are filled in. Secrets must be set in Vercel dashboard.
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Auth Service
PORT=3001
APP_URL=https://mon-auth.vercel.app
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=production
GLOBAL_PREFIX=api/auth
CORS_ORIGINS=https://monluxury.vercel.app

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=

# -- Redis ---------------------------------------------------------------------
REDIS_URL=

# -- JWT -----------------------------------------------------------------------
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# -- Google OAuth --------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://mon-auth.vercel.app/api/auth/google/callback
GOOGLE_FRONTEND_URL=https://monluxury.vercel.app
GOOGLE_OAUTH_STATE_SECRET=

# -- Security ------------------------------------------------------------------
SECURITY_ATTEMPT_MAX=5
SECURITY_ATTEMPT_WINDOW_SECONDS=900
SECURITY_ATTEMPT_LOCKOUT_SECONDS=1800
OTP_TTL_SECONDS=300
BCRYPT_ROUNDS=12

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=

# -- Messaging -----------------------------------------------------------------
EVENT_DRIVER=local
RABBITMQ_URL=
REDIS_EVENT_URL=
REDIS_STREAM_MAX_LEN=10000
KAFKA_BROKERS=
KAFKA_GROUP_ID=auth-service
KAFKA_REPLICATION_FACTOR=1
KAFKA_LINGER_MS=
KAFKA_BATCH_SIZE=
KAFKA_COMPRESSION=
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# -- Observability -------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
