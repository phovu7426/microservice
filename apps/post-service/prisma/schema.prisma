generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id             BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  description    String?  @db.Text
  parentId       BigInt?  @map("parent_id")
  status         String   @default("active") @map("status")
  sortOrder      Int      @default(0) @map("sort_order")
  seoTitle       String?  @map("seo_title") @db.VarChar(255)
  seoDescription String?  @map("seo_description") @db.Text
  seoKeywords    String?  @map("seo_keywords") @db.VarChar(500)
  createdUserId  BigInt?  @map("created_user_id")
  updatedUserId  BigInt?  @map("updated_user_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  groupId        BigInt?  @map("group_id")

  parent   Category?      @relation("CategoryToChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]     @relation("CategoryToChildren")
  posts    PostCategory[]

  @@index([slug], map: "categories_idx_slug")
  @@index([name], map: "categories_idx_name")
  @@index([parentId], map: "categories_idx_parent_id")
  @@index([status], map: "categories_idx_status")
  @@index([sortOrder], map: "categories_idx_sort_order")
  @@index([createdAt], map: "categories_idx_created_at")
  @@index([createdUserId], map: "categories_idx_created_user_id")
  @@index([updatedUserId], map: "categories_idx_updated_user_id")
  @@index([groupId], map: "categories_idx_group_id")
  @@map("categories")
}

model Tag {
  id             BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  description    String?  @db.Text
  status         String   @default("active") @map("status")
  createdUserId  BigInt?  @map("created_user_id")
  updatedUserId  BigInt?  @map("updated_user_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  groupId        BigInt?  @map("group_id")

  posts PostTag[]

  @@index([slug], map: "tags_idx_slug")
  @@index([name], map: "tags_idx_name")
  @@index([status], map: "tags_idx_status")
  @@index([createdAt], map: "tags_idx_created_at")
  @@index([createdUserId], map: "tags_idx_created_user_id")
  @@index([updatedUserId], map: "tags_idx_updated_user_id")
  @@index([groupId], map: "tags_idx_group_id")
  @@map("tags")
}

model Post {
  id             BigInt    @id @default(autoincrement())
  name           String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  excerpt        String?   @db.Text
  content        String?   @db.Text
  image          String?   @db.VarChar(500)
  coverImage     String?   @map("cover_image") @db.VarChar(500)
  status         String    @default("draft") @db.VarChar(30)
  postType       String    @default("text") @map("post_type") @db.VarChar(30)
  videoUrl       String?   @map("video_url") @db.VarChar(500)
  audioUrl       String?   @map("audio_url") @db.VarChar(500)
  isFeatured     Boolean   @default(false) @map("is_featured")
  isPinned       Boolean   @default(false) @map("is_pinned")
  publishedAt    DateTime? @map("published_at") @db.Timestamp(0)
  seoTitle       String?   @map("seo_title") @db.VarChar(255)
  seoDescription String?   @map("seo_description") @db.Text
  seoKeywords    String?   @map("seo_keywords") @db.VarChar(500)
  createdUserId  BigInt?   @map("created_user_id")
  updatedUserId  BigInt?   @map("updated_user_id")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  groupId        BigInt?   @map("group_id")

  stats         Stats?
  daily_stats   DailyStats[]
  categoryLinks PostCategory[]
  tagLinks      PostTag[]
  comments      Comment[]

  @@index([slug], map: "posts_idx_slug")
  @@index([status], map: "posts_idx_status")
  @@index([postType], map: "posts_idx_post_type")
  @@index([isFeatured], map: "posts_idx_is_featured")
  @@index([isPinned], map: "posts_idx_is_pinned")
  @@index([publishedAt], map: "posts_idx_published_at")
  // Composite index for the public list. Filter is `status IN (...)` and
  // ordering is by `published_at DESC` — without this composite, Postgres
  // can use only one of the two single-column indexes per query.
  @@index([status, publishedAt(sort: Desc)], map: "posts_idx_status_published_at")
  @@index([status, isFeatured], map: "posts_idx_status_featured")
  @@index([status, isPinned], map: "posts_idx_status_pinned")
  @@index([createdAt], map: "posts_idx_created_at")
  @@index([createdUserId], map: "posts_idx_created_user_id")
  @@index([updatedUserId], map: "posts_idx_updated_user_id")
  @@index([groupId], map: "posts_idx_group_id")
  @@map("posts")
}

model Stats {
  postId    BigInt   @id @map("post_id")
  viewCount BigInt   @default(0) @map("view_count")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([viewCount], map: "stats_idx_view_count")
  @@index([updatedAt], map: "stats_idx_updated_at")
  @@map("stats")
}

model DailyStats {
  postId    BigInt   @map("post_id")
  statDate  DateTime @map("stat_date") @db.Date
  viewCount BigInt   @default(0) @map("view_count")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, statDate])
  @@index([statDate], map: "daily_stats_idx_stat_date")
  @@index([viewCount], map: "daily_stats_idx_view_count")
  @@map("daily_stats")
}

model PostCategory {
  postId     BigInt @map("post_id")
  categoryId BigInt @map("category_id")

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId], map: "post_categories_idx_category_id")
  @@map("post_categories")
}

model PostTag {
  postId BigInt @map("post_id")
  tagId  BigInt @map("tag_id")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId], map: "post_tags_idx_tag_id")
  @@map("post_tags")
}

model Comment {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt?  @map("user_id")
  postId        BigInt   @map("post_id")
  parentId      BigInt?  @map("parent_id")
  guestName     String?  @map("guest_name") @db.VarChar(255)
  guestEmail    String?  @map("guest_email") @db.VarChar(255)
  content       String   @db.Text
  status        String   @default("visible") @db.VarChar(30)
  createdUserId BigInt?  @map("created_user_id")
  updatedUserId BigInt?  @map("updated_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  // SetNull (was Cascade): admin hard-delete of one parent comment used to
  // wipe the entire reply subtree even though user-side delete already
  // soft-deletes via status='deleted'. Replies now survive with parent_id
  // = NULL; the renderer can display "[deleted]" for missing parents.
  parent  Comment?  @relation("CommentToReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentToReplies")

  @@index([userId], map: "comments_idx_user_id")
  @@index([postId], map: "comments_idx_post_id")
  @@index([parentId], map: "comments_idx_parent_id")
  @@index([status], map: "comments_idx_status")
  @@index([createdAt], map: "comments_idx_created_at")
  @@index([postId, createdAt], map: "comments_idx_post_created")
  @@index([guestEmail], map: "comments_idx_guest_email")
  @@index([createdUserId], map: "comments_idx_created_user_id")
  @@index([updatedUserId], map: "comments_idx_updated_user_id")
  @@map("comments")
}

model Outbox {
  id        BigInt   @id @default(autoincrement())
  eventType String   @map("event_type") @db.VarChar(100)
  payload   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([published, createdAt], map: "outbox_idx_unpublished")
  @@map("outbox")
}
