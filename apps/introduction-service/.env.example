# =============================================================================
# Introduction Service — Environment Variables
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=introduction-service
PORT=3007
NODE_ENV=development
GLOBAL_PREFIX=api/introduction
APP_URL=http://localhost:3007
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5439/introduction_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6387

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json
INTERNAL_API_SECRET=change-me-in-production

# ── IAM ───────────────────────────────────────────────────────────────────────
IAM_INTERNAL_URL=http://localhost:3002/api/iam

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
