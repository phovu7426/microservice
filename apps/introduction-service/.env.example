# =============================================================================
# Introduction Service — Environment Variables
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
SERVICE_NAME=Introduction Service
PORT=3007
APP_URL=http://localhost:3007
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api/introduction
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5432/introduction_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Guard (consumer) ──────────────────────────────────────────────────────
# Leave blank to disable; uses shared JWKS from auth-service
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
