{
  "version": 2,
  "installCommand": "cd ../.. && NPM_CONFIG_SHAMEFULLY_HOIST=true pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm build:shared",
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.ts" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "src/i18n/**"
    }
  }
}
