{
  "name": "storage-service",
  "version": "1.0.0",
  "description": "Standalone file upload/storage microservice",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts,json --exec \"ts-node --swc -r tsconfig-paths/register src/main.ts\"",
    "build": "tsc",
    "start:prod": "node -r tsconfig-paths/register dist/main.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@package/bootstrap": "workspace:*",
    "@package/common": "workspace:*",
    "@package/config": "workspace:*",
    "@package/redis": "workspace:*",
    "@package/tracing": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "joi": "^18.1.2",
    "jose": "^6.2.3",
    "nestjs-i18n": "^10.8.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
