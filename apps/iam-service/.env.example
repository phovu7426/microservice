# =============================================================================
# IAM Service — Environment Variables
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=IAM Service
PORT=3002
NODE_ENV=development
GLOBAL_PREFIX=api/iam
APP_URL=http://localhost:3002
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5441/iam_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6385

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# ── RBAC ──────────────────────────────────────────────────────────────────────
RBAC_CACHE_TTL=86400

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production

# ── Kafka ─────────────────────────────────────────────────────────────────────
EVENT_DRIVER=local
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=iam-service
KAFKA_REPLICATION_FACTOR=3
# SSL for Aiven Kafka — leave empty for local plaintext
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
