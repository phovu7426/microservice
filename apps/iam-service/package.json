{
  "name": "iam-service",
  "version": "1.0.0",
  "description": "Identity and Access Management microservice — Comic Platform",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts,json --exec \"ts-node --swc -r tsconfig-paths/register src/main.ts\"",
    "build": "prisma generate && tsc",
    "start:prod": "node -r tsconfig-paths/register dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node -P tsconfig.seed.json prisma/seed/index.ts",
    "seed": "npm run prisma:seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@package/bootstrap": "workspace:*",
    "@package/common": "workspace:*",
    "@package/config": "workspace:*",
    "@package/kafka-client": "workspace:*",
    "@package/rabbitmq-client": "workspace:*",
    "@package/redis": "workspace:*",
    "@package/redis-client": "workspace:*",
    "@package/tracing": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.8.2",
    "joi": "^18.1.2",
    "jose": "^6.2.3",
    "nestjs-i18n": "^10.8.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
