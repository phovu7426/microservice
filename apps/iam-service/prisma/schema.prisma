generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Context — scope container for roles & groups
// ============================================

model Context {
  id              BigInt   @id @default(autoincrement())
  type            String   @db.VarChar(50)
  ref_id          BigInt?
  name            String   @db.VarChar(255)
  code            String   @unique @db.VarChar(100)
  status          String   @default("active") @db.VarChar(30)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  groups        Group[]
  role_contexts RoleContext[]

  @@unique([type, ref_id], map: "contexts_idx_contexts_type_ref_id")
  @@map("contexts")
}

// ============================================
// Group — organisational unit within a context
// ============================================

model Group {
  id              BigInt   @id @default(autoincrement())
  type            String   @db.VarChar(50)
  code            String   @unique @db.VarChar(100)
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  status          String   @default("active") @db.VarChar(30)
  owner_id        BigInt?
  context_id      BigInt
  metadata        Json?
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  context               Context              @relation(fields: [context_id], references: [id], onDelete: Restrict)
  user_groups           UserGroup[]
  user_role_assignments UserRoleAssignment[]

  @@unique([type, code], map: "groups_idx_groups_type_code")
  @@index([context_id], map: "groups_IDX_groups_context_id")
  @@map("groups")
}

// user_id is an application-level reference to auth-service.users (no DB FK)
model UserGroup {
  user_id   BigInt
  group_id  BigInt
  joined_at DateTime @default(now()) @db.Timestamp(0)

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@id([user_id, group_id])
  @@index([user_id], map: "user_groups_idx_user_groups_user_id")
  @@index([user_id, joined_at], map: "user_groups_idx_user_groups_user_joined_at")
  @@index([group_id], map: "user_groups_idx_user_groups_group_id")
  @@index([group_id, user_id], map: "user_groups_idx_group_user")
  @@map("user_groups")
}

// ============================================
// Permission — individual access right (hierarchical)
// ============================================

model Permission {
  id              BigInt   @id @default(autoincrement())
  code            String   @unique @db.VarChar(120)
  scope           String   @default("context") @db.VarChar(30)
  name            String?  @db.VarChar(150)
  status          String   @default("active") @db.VarChar(30)
  parent_id       BigInt?
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  parent     Permission?         @relation("PermissionHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children   Permission[]        @relation("PermissionHierarchy")
  role_links RoleHasPermission[]

  @@index([scope], map: "permissions_idx_scope")
  @@index([parent_id], map: "permissions_idx_permissions_parent_id")
  @@map("permissions")
}

// ============================================
// Role — permission container (hierarchical)
// ============================================

model Role {
  id              BigInt   @id @default(autoincrement())
  code            String   @db.VarChar(100)
  name            String?  @db.VarChar(150)
  status          String   @default("active") @db.VarChar(30)
  parent_id       BigInt?
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  parent                Role?                @relation("RoleHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children              Role[]               @relation("RoleHierarchy")
  permissions           RoleHasPermission[]
  role_contexts         RoleContext[]
  user_role_assignments UserRoleAssignment[]

  @@unique([code], map: "roles_code_key")
  @@map("roles")
}

model RoleHasPermission {
  role_id       BigInt @db.BigInt
  permission_id BigInt @db.BigInt

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([role_id], map: "role_has_permissions_idx_role_has_permissions_role_id")
  @@index([permission_id], map: "role_has_permissions_idx_role_has_permissions_permission_id")
  @@map("role_has_permissions")
}

model RoleContext {
  role_id    BigInt @db.BigInt
  context_id BigInt @db.BigInt

  role    Role    @relation(fields: [role_id], references: [id], onDelete: Cascade)
  context Context @relation(fields: [context_id], references: [id], onDelete: Cascade)

  @@id([role_id, context_id])
  @@index([role_id], map: "role_contexts_idx_role_contexts_role_id")
  @@index([context_id], map: "role_contexts_idx_role_contexts_context_id")
  @@map("role_contexts")
}

// user_id is an application-level reference to auth-service.users (no DB FK)
model UserRoleAssignment {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  role_id    BigInt
  group_id   BigInt
  created_at DateTime @default(now()) @db.Timestamp(0)

  role  Role  @relation(fields: [role_id], references: [id], onDelete: Cascade)
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id, group_id], map: "user_role_assignments_idx_user_role_group_unique")
  @@index([user_id, group_id], map: "user_role_assignments_idx_user_group")
  @@index([group_id, user_id], map: "user_role_assignments_idx_group_user")
  @@index([group_id], map: "user_role_assignments_idx_user_role_assignments_group_id")
  @@index([role_id], map: "user_role_assignments_idx_user_role_assignments_role_id")
  @@map("user_role_assignments")
}

// ============================================
// Outbox Pattern — Kafka at-least-once delivery
// ============================================

model Outbox {
  id         BigInt   @id @default(autoincrement())
  event_type String   @db.VarChar(100)
  payload    Json
  published  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([published, created_at])
  @@map("outbox")
}
