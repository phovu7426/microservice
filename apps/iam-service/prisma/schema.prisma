generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Context — scope container for roles & groups
// ============================================

model Context {
  id            BigInt   @id @default(autoincrement())
  type          String   @db.VarChar(50)
  refId         BigInt?  @map("ref_id")
  name          String   @db.VarChar(255)
  code          String   @unique @db.VarChar(100)
  status        String   @default("active") @db.VarChar(30)
  createdUserId BigInt?  @map("created_user_id")
  updatedUserId BigInt?  @map("updated_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  groups       Group[]
  roleContexts RoleContext[]

  @@unique([type, refId], map: "contexts_idx_contexts_type_ref_id")
  @@map("contexts")
}

// ============================================
// Group — organisational unit within a context
// ============================================

model Group {
  id            BigInt   @id @default(autoincrement())
  type          String   @db.VarChar(50)
  code          String   @unique @db.VarChar(100)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  status        String   @default("active") @db.VarChar(30)
  ownerId       BigInt?  @map("owner_id")
  contextId     BigInt   @map("context_id")
  metadata      Json?
  createdUserId BigInt?  @map("created_user_id")
  updatedUserId BigInt?  @map("updated_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  context             Context              @relation(fields: [contextId], references: [id], onDelete: Restrict)
  userGroups          UserGroup[]
  userRoleAssignments UserRoleAssignment[]

  @@unique([type, code], map: "groups_idx_groups_type_code")
  @@index([contextId], map: "groups_IDX_groups_context_id")
  @@map("groups")
}

// user_id is an application-level reference to auth-service.users (no DB FK)
model UserGroup {
  userId   BigInt   @map("user_id")
  groupId  BigInt   @map("group_id")
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamp(0)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([userId], map: "user_groups_idx_user_groups_user_id")
  @@index([userId, joinedAt], map: "user_groups_idx_user_groups_user_joined_at")
  @@index([groupId], map: "user_groups_idx_user_groups_group_id")
  @@index([groupId, userId], map: "user_groups_idx_group_user")
  @@map("user_groups")
}

// ============================================
// Permission — individual access right (hierarchical)
// ============================================

model Permission {
  id            BigInt   @id @default(autoincrement())
  code          String   @unique @db.VarChar(120)
  scope         String   @default("context") @db.VarChar(30)
  name          String?  @db.VarChar(150)
  status        String   @default("active") @db.VarChar(30)
  parentId      BigInt?  @map("parent_id")
  createdUserId BigInt?  @map("created_user_id")
  updatedUserId BigInt?  @map("updated_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  parent    Permission?         @relation("PermissionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Permission[]        @relation("PermissionHierarchy")
  roleLinks RoleHasPermission[]

  @@index([scope], map: "permissions_idx_scope")
  @@index([parentId], map: "permissions_idx_permissions_parent_id")
  @@map("permissions")
}

// ============================================
// Role — permission container (hierarchical)
// ============================================

model Role {
  id            BigInt   @id @default(autoincrement())
  code          String   @db.VarChar(100)
  name          String?  @db.VarChar(150)
  status        String   @default("active") @db.VarChar(30)
  parentId      BigInt?  @map("parent_id")
  createdUserId BigInt?  @map("created_user_id")
  updatedUserId BigInt?  @map("updated_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  parent              Role?                @relation("RoleHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children            Role[]               @relation("RoleHierarchy")
  permissions         RoleHasPermission[]
  roleContexts        RoleContext[]
  userRoleAssignments UserRoleAssignment[]

  @@unique([code], map: "roles_code_key")
  @@map("roles")
}

model RoleHasPermission {
  roleId       BigInt @map("role_id") @db.BigInt
  permissionId BigInt @map("permission_id") @db.BigInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId], map: "role_has_permissions_idx_role_has_permissions_role_id")
  @@index([permissionId], map: "role_has_permissions_idx_role_has_permissions_permission_id")
  @@map("role_has_permissions")
}

model RoleContext {
  roleId    BigInt @map("role_id") @db.BigInt
  contextId BigInt @map("context_id") @db.BigInt

  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  context Context @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@id([roleId, contextId])
  @@index([roleId], map: "role_contexts_idx_role_contexts_role_id")
  @@index([contextId], map: "role_contexts_idx_role_contexts_context_id")
  @@map("role_contexts")
}

// user_id is an application-level reference to auth-service.users (no DB FK)
model UserRoleAssignment {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  groupId   BigInt   @map("group_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, groupId], map: "user_role_assignments_idx_user_role_group_unique")
  @@index([userId, groupId], map: "user_role_assignments_idx_user_group")
  @@index([groupId, userId], map: "user_role_assignments_idx_group_user")
  @@index([groupId], map: "user_role_assignments_idx_user_role_assignments_group_id")
  @@index([roleId], map: "user_role_assignments_idx_user_role_assignments_role_id")
  @@map("user_role_assignments")
}

// ============================================
// Outbox Pattern — Kafka at-least-once delivery
// ============================================

model Outbox {
  id        BigInt   @id @default(autoincrement())
  eventType String   @map("event_type") @db.VarChar(100)
  payload   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([published, createdAt])
  @@map("outbox")
}
