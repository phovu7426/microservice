# =============================================================================
# Marketing Service — Environment Variables
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
SERVICE_NAME=Marketing Service
PORT=3006
APP_URL=http://localhost:3006
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api/marketing
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5432/marketing_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Guard (consumer) ──────────────────────────────────────────────────────
# Leave blank to disable; uses shared JWKS from auth-service
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production

# ── Messaging ─────────────────────────────────────────────────────────────────
# Chọn broker: kafka | rabbitmq | redis
# - redis: dùng Redis Streams, không cần broker riêng (recommended cho local/dev)
# - rabbitmq: dùng cho staging/production với RabbitMQ cluster
# - kafka: dùng cho production với Kafka cluster (Aiven, Confluent, ...)
EVENT_DRIVER=redis

# Redis Streams (dùng khi EVENT_DRIVER=redis) — Redis server riêng cho events
REDIS_EVENT_URL=redis://localhost:6380
REDIS_STREAM_MAX_LEN=10000

# RabbitMQ (dùng khi EVENT_DRIVER=rabbitmq)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Kafka (dùng khi EVENT_DRIVER=kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_LINGER_MS=100
KAFKA_BATCH_SIZE=32768
KAFKA_COMPRESSION=snappy
KAFKA_GROUP_ID=marketing-service
KAFKA_REPLICATION_FACTOR=3
# SSL for Aiven Kafka — leave empty for local plaintext
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
