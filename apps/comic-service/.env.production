# =============================================================================
# Comic Service — Production overrides
# Priority: .env.local > .env.production > .env
# Non-secret vars are filled in. Secrets must be set in Vercel dashboard.
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Comic Service
PORT=3009
APP_URL=https://mon-comic.vercel.app
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=production
GLOBAL_PREFIX=api/comics
CORS_ORIGINS=https://monluxury.vercel.app

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=

# -- Redis ---------------------------------------------------------------------
REDIS_URL=

# -- JWT Guard (consumer) ------------------------------------------------------
AUTH_JWKS_URL=https://mon-auth.vercel.app/.well-known/jwks.json

# -- IAM -----------------------------------------------------------------------
IAM_INTERNAL_URL=https://mon-iam.vercel.app/api/iam

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=

# -- Messaging -----------------------------------------------------------------
EVENT_DRIVER=local
RABBITMQ_URL=
REDIS_EVENT_URL=
REDIS_STREAM_MAX_LEN=10000
KAFKA_BROKERS=
KAFKA_GROUP_ID=comic-service
KAFKA_REPLICATION_FACTOR=1
KAFKA_LINGER_MS=
KAFKA_BATCH_SIZE=
KAFKA_COMPRESSION=
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# -- Observability -------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
