generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Comic {
  id                   BigInt    @id @default(autoincrement())
  slug                 String    @unique @db.VarChar(255)
  title                String    @db.VarChar(255)
  description          String?   @db.Text
  coverImage           String?   @map("cover_image") @db.VarChar(500)
  author               String?   @db.VarChar(255)
  status               String    @default("draft") @db.VarChar(30)
  createdUserId        BigInt?   @map("created_user_id")
  updatedUserId        BigInt?   @map("updated_user_id")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  lastChapterId        BigInt?   @map("last_chapter_id")
  lastChapterUpdatedAt DateTime? @map("last_chapter_updated_at") @db.Timestamp(0)
  isFeatured           Boolean   @default(false) @map("is_featured")
  groupId              BigInt?   @map("group_id")

  stats             Stats?
  dailyStats        DailyStats[]
  chapters          Chapter[]
  lastChapter       Chapter?         @relation("LastChapter", fields: [lastChapterId], references: [id], onDelete: SetNull)
  categoryLinks     ComicCategory[]
  comments          Comment[]
  reviews           Review[]
  views             View[]
  follows           Follow[]
  readingHistories  ReadingHistory[]

  @@index([slug], map: "comics_idx_slug")
  @@index([status], map: "comics_idx_status")
  @@index([author], map: "comics_idx_author")
  @@index([createdAt], map: "comics_idx_created_at")
  @@index([createdUserId], map: "comics_idx_created_user_id")
  @@index([updatedUserId], map: "comics_idx_updated_user_id")
  @@index([lastChapterUpdatedAt], map: "comics_idx_last_chapter_updated_at")
  @@index([isFeatured], map: "comics_idx_is_featured")
  @@index([groupId], map: "comics_idx_group_id")
  @@index([status, lastChapterUpdatedAt(sort: Desc)], map: "comics_idx_status_last_chapter_updated")
  @@index([status, isFeatured], map: "comics_idx_status_featured")
  @@index([status, createdAt(sort: Desc)], map: "comics_idx_status_created")
  @@map("comics")
}

model Stats {
  comicId     BigInt   @id @map("comic_id")
  viewCount   BigInt   @default(0) @map("view_count")
  followCount BigInt   @default(0) @map("follow_count")
  ratingCount BigInt   @default(0) @map("rating_count")
  ratingSum   BigInt   @default(0) @map("rating_sum")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  comic Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@index([viewCount], map: "stats_idx_view_count")
  @@index([followCount], map: "stats_idx_follow_count")
  @@index([updatedAt], map: "stats_idx_updated_at")
  @@map("stats")
}

model DailyStats {
  comicId   BigInt   @map("comic_id")
  statDate  DateTime @map("stat_date") @db.Date
  viewCount BigInt   @default(0) @map("view_count")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  comic Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@id([comicId, statDate])
  @@index([statDate], map: "daily_stats_idx_stat_date")
  @@index([viewCount], map: "daily_stats_idx_view_count")
  @@map("daily_stats")
}

model Chapter {
  id             BigInt   @id @default(autoincrement())
  comicId        BigInt   @map("comic_id")
  teamId         BigInt?  @map("team_id")
  title          String   @db.VarChar(255)
  chapterIndex   Int      @map("chapter_index")
  chapterLabel   String?  @map("chapter_label") @db.VarChar(50)
  status         String   @default("draft") @db.VarChar(30)
  viewCount      BigInt   @default(0) @map("view_count")
  createdUserId  BigInt?  @map("created_user_id")
  updatedUserId  BigInt?  @map("updated_user_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  groupId        BigInt?  @map("group_id")

  comic             Comic            @relation(fields: [comicId], references: [id], onDelete: Cascade)
  comicsLastChapter  Comic[]          @relation("LastChapter")
  pages             Page[]
  views             View[]
  comments          Comment[]
  readingHistories  ReadingHistory[]
  bookmarks         Bookmark[]

  @@unique([comicId, chapterIndex], map: "chapters_idx_comic_chapter_unique")
  @@index([comicId], map: "chapters_idx_comic_id")
  @@index([comicId, chapterIndex], map: "chapters_idx_comic_chapter_index")
  @@index([teamId], map: "chapters_idx_team_id")
  @@index([status], map: "chapters_idx_status")
  @@index([viewCount], map: "chapters_idx_view_count")
  @@index([createdAt], map: "chapters_idx_created_at")
  @@index([createdUserId], map: "chapters_idx_created_user_id")
  @@index([updatedUserId], map: "chapters_idx_updated_user_id")
  @@index([groupId], map: "chapters_idx_group_id")
  @@map("chapters")
}

model Category {
  id             BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(255)
  description    String?  @db.Text
  createdUserId  BigInt?  @map("created_user_id")
  updatedUserId  BigInt?  @map("updated_user_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  groupId        BigInt?  @map("group_id")

  comics ComicCategory[]

  @@index([slug], map: "categories_idx_slug")
  @@index([name], map: "categories_idx_name")
  @@index([createdAt], map: "categories_idx_created_at")
  @@index([createdUserId], map: "categories_idx_created_user_id")
  @@index([updatedUserId], map: "categories_idx_updated_user_id")
  @@index([groupId], map: "categories_idx_group_id")
  @@map("categories")
}

model ComicCategory {
  comicId    BigInt @map("comic_id")
  categoryId BigInt @map("category_id")

  comic    Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([comicId, categoryId])
  @@index([categoryId], map: "comic_categories_idx_category_id")
  @@map("comic_categories")
}

model Comment {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  comicId        BigInt   @map("comic_id")
  chapterId      BigInt?  @map("chapter_id")
  parentId       BigInt?  @map("parent_id")
  content        String   @db.Text
  status         String   @default("visible") @db.VarChar(30)
  createdUserId  BigInt?  @map("created_user_id")
  updatedUserId  BigInt?  @map("updated_user_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  comic   Comic     @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  // SetNull (was Cascade): admin hard-delete of one parent comment used to
  // wipe the entire reply subtree even though user-side delete already
  // soft-deletes via status='deleted'. Replies now survive with parentId
  // = NULL; the renderer can display "[deleted]" for missing parents.
  parent  Comment?  @relation("CommentToReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentToReplies")

  @@index([userId], map: "comments_idx_user_id")
  @@index([comicId], map: "comments_idx_comic_id")
  @@index([chapterId], map: "comments_idx_chapter_id")
  @@index([parentId], map: "comments_idx_parent_id")
  @@index([status], map: "comments_idx_status")
  @@index([createdAt], map: "comments_idx_created_at")
  @@index([comicId, createdAt], map: "comments_idx_comic_created")
  @@index([chapterId, createdAt], map: "comments_idx_chapter_created")
  @@index([createdUserId], map: "comments_idx_created_user_id")
  @@index([updatedUserId], map: "comments_idx_updated_user_id")
  @@map("comments")
}

model Review {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  comicId        BigInt   @map("comic_id")
  rating         Int      @db.SmallInt
  content        String?  @db.Text
  createdUserId  BigInt?  @map("created_user_id")
  updatedUserId  BigInt?  @map("updated_user_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  comic Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId], map: "reviews_idx_user_comic")
  @@index([userId], map: "reviews_idx_user_id")
  @@index([comicId], map: "reviews_idx_comic_id")
  @@index([rating], map: "reviews_idx_rating")
  @@index([createdAt], map: "reviews_idx_created_at")
  @@index([createdUserId], map: "reviews_idx_created_user_id")
  @@index([updatedUserId], map: "reviews_idx_updated_user_id")
  @@map("reviews")
}

model Page {
  id         BigInt   @id @default(autoincrement())
  chapterId  BigInt   @map("chapter_id")
  pageNumber Int      @map("page_number")
  imageUrl   String   @map("image_url") @db.VarChar(500)
  width      Int?
  height     Int?
  fileSize   BigInt?  @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, pageNumber], map: "pages_idx_chapter_page_unique")
  @@index([chapterId], map: "pages_idx_chapter_id")
  @@index([chapterId, pageNumber], map: "pages_idx_chapter_page")
  @@map("pages")
}

model View {
  id        BigInt   @id @default(autoincrement())
  comicId   BigInt   @map("comic_id")
  chapterId BigInt?  @map("chapter_id")
  userId    BigInt?  @map("user_id")
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  comic   Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([comicId], map: "views_idx_comic_id")
  @@index([chapterId], map: "views_idx_chapter_id")
  @@index([userId], map: "views_idx_user_id")
  @@index([createdAt], map: "views_idx_created_at")
  @@index([comicId, createdAt], map: "views_idx_comic_created")
  @@index([chapterId, createdAt], map: "views_idx_chapter_created")
  @@map("views")
}

model Follow {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  comicId   BigInt   @map("comic_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  comic Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId], map: "follows_idx_user_comic")
  @@index([userId], map: "follows_idx_user_id")
  @@index([comicId], map: "follows_idx_comic_id")
  @@index([createdAt], map: "follows_idx_created_at")
  @@map("follows")
}

model ReadingHistory {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  comicId   BigInt   @map("comic_id")
  chapterId BigInt   @map("chapter_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  comic   Comic   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId], map: "reading_histories_idx_user_comic")
  @@index([userId], map: "reading_histories_idx_user_id")
  @@index([comicId], map: "reading_histories_idx_comic_id")
  @@index([chapterId], map: "reading_histories_idx_chapter_id")
  @@index([updatedAt], map: "reading_histories_idx_updated_at")
  @@map("reading_histories")
}

model Bookmark {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  chapterId  BigInt   @map("chapter_id")
  pageNumber Int      @map("page_number")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // Unique on (user, chapter, page) so double-tap doesn't insert two rows
  // for the same bookmark; the service uses upsert against this constraint.
  @@unique([userId, chapterId, pageNumber], map: "bookmarks_idx_user_chapter_page_unique")
  @@index([userId], map: "bookmarks_idx_user_id")
  @@index([chapterId], map: "bookmarks_idx_chapter_id")
  @@index([userId, chapterId], map: "bookmarks_idx_user_chapter")
  @@index([createdAt], map: "bookmarks_idx_created_at")
  @@map("bookmarks")
}

model Outbox {
  id        BigInt   @id @default(autoincrement())
  eventType String   @map("event_type") @db.VarChar(100)
  payload   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([published, createdAt], map: "outbox_idx_unpublished")
  @@map("outbox")
}
