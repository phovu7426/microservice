{
  "name": "gateway-service",
  "version": "1.0.0",
  "description": "API gateway aggregating upstream services for frontend clients",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "build": "tsc",
    "start:prod": "node -r tsconfig-paths/register dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@package/bootstrap": "workspace:*",
    "@package/circuit-breaker": "workspace:*",
    "@package/common": "workspace:*",
    "@package/config": "workspace:*",
    "@package/tracing": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cockatiel": "^3.2.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.8.2",
    "joi": "^18.1.2",
    "jose": "^4.15.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
