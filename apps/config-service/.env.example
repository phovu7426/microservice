# =============================================================================
# Config Service — Environment Variables
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Config Service
PORT=3003
NODE_ENV=development
GLOBAL_PREFIX=api/config
APP_URL=http://localhost:3003
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5436/config_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json
INTERNAL_API_SECRET=change-me-in-production

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
