{
  "name": "comic-platform",
  "version": "2.0.0",
  "description": "Comic Platform — Microservices Architecture",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "pnpm run build:shared",
    "build:shared": "pnpm --filter \"./packages/*\" -r build",
    "build:auth": "pnpm --filter auth-service build",
    "build:comic": "pnpm --filter comic-service build",
    "build:config": "pnpm --filter config-service build",
    "build:web-api": "pnpm --filter web-api-service build",
    "build:iam": "pnpm --filter iam-service build",
    "build:cms": "pnpm --filter cms-service build",
    "build:notification": "pnpm --filter notification-service build",
    "build:post": "pnpm --filter post-service build",
    "build:storage": "pnpm --filter storage-service build",
    "build:apps": "pnpm --filter \"./apps/*\" -r build",
    "build": "pnpm run build:shared && pnpm run build:apps",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start:auth": "pnpm --filter auth-service start",
    "start:comic": "pnpm --filter comic-service start",
    "start:config": "pnpm --filter config-service start",
    "start:web-api": "pnpm --filter web-api-service start",
    "start:iam": "pnpm --filter iam-service start",
    "start:cms": "pnpm --filter cms-service start",
    "start:notification": "pnpm --filter notification-service start",
    "start:post": "pnpm --filter post-service start",
    "start:storage": "pnpm --filter storage-service start",
    "start": "concurrently --prefix-colors blue,magenta,cyan,green,yellow,red,white,gray,blueBright -n auth,comic,config,web-api,iam,cms,notification,post,storage \"pnpm run start:auth\" \"pnpm run start:comic\" \"pnpm run start:config\" \"pnpm run start:web-api\" \"pnpm run start:iam\" \"pnpm run start:cms\" \"pnpm run start:notification\" \"pnpm run start:post\" \"pnpm run start:storage\"",
    "dev:auth": "pnpm --filter auth-service start:dev",
    "dev:comic": "pnpm --filter comic-service start:dev",
    "dev:config": "pnpm --filter config-service start:dev",
    "dev:web-api": "pnpm --filter web-api-service start:dev",
    "dev:iam": "pnpm --filter iam-service start:dev",
    "dev:cms": "pnpm --filter cms-service start:dev",
    "dev:notification": "pnpm --filter notification-service start:dev",
    "dev:post": "pnpm --filter post-service start:dev",
    "dev:storage": "pnpm --filter storage-service start:dev",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=300 concurrently --prefix-colors blue,magenta,cyan,red,white,gray,blueBright,magentaBright -n auth,comic,config,cms,notification,post,storage,iam \"pnpm run dev:auth\" \"pnpm run dev:comic\" \"pnpm run dev:config\" \"pnpm run dev:cms\" \"pnpm run dev:notification\" \"pnpm run dev:post\" \"pnpm run dev:storage\" \"pnpm run dev:iam\"",
    "prisma:generate:auth": "pnpm --filter auth-service prisma:generate",
    "prisma:generate:comic": "pnpm --filter comic-service prisma:generate",
    "prisma:generate:config": "pnpm --filter config-service prisma:generate",
    "prisma:generate:iam": "pnpm --filter iam-service prisma:generate",
    "prisma:generate:cms": "pnpm --filter cms-service prisma:generate",
    "prisma:generate:notification": "pnpm --filter notification-service prisma:generate",
    "prisma:generate:post": "pnpm --filter post-service prisma:generate",
    "prisma:generate": "pnpm --filter \"./apps/*\" -r --workspace-concurrency=1 --if-present prisma:generate",
    "prisma:migrate": "pnpm --filter \"./apps/*\" -r --workspace-concurrency=1 --if-present prisma:migrate",
    "prisma:deploy": "pnpm --filter \"./apps/*\" -r --workspace-concurrency=1 --if-present prisma:migrate:deploy",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:infra": "docker compose up -d kafka kafka-ui rabbitmq auth-db comic-db notification-db config-db post-db cms-db iam-db auth-redis comic-redis notification-redis post-redis web-api-redis iam-redis jaeger",
    "docker:infra:down": "docker compose stop kafka kafka-ui auth-db comic-db notification-db config-db post-db cms-db iam-db auth-redis comic-redis notification-redis post-redis web-api-redis iam-redis jaeger",
    "nginx:up": "docker compose --profile dev up -d nginx-dev",
    "nginx:down": "docker compose --profile dev rm -sf nginx-dev",
    "production:check": "./scripts/production-ready-check.sh",
    "production:ready": "./scripts/make-production-ready.sh"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/compression": "^1.8.1",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0"
  }
}
